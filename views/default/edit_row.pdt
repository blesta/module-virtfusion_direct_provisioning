<?php /** @var View $this **/ ?>

<?php
$this->Widget->clear();

$this->Widget->setLinkButtons([
    [
        'name' => $this->_('Virtfusion.back_to_manage', true),
        'icon' => 'bi bi-arrow-left me-1',
        'attributes' => ['href' => $this->base_uri . 'settings/company/modules/manage/' . $module->id],
    ],
]);

$this->Widget->create($this->_('VirtfusionDirectProvisioning.edit_row.box_title', true));

$this->Form->create(null, ['class' => 'disable-on-submit']);
?>

<div class="mb-3">
    <label for="name" class="form-label">
        <?php $this->_('VirtfusionDirectProvisioning.row_meta.name'); ?>
    </label>
    <?php $this->Form->fieldText('name', $vars->name ?? null, ['id' => 'name', 'class' => 'form-control']); ?>
</div>

<div class="mb-3">
    <label for="hostname" class="form-label">
        <?php $this->_('VirtfusionDirectProvisioning.row_meta.hostname'); ?>
    </label>
    <?php $this->Form->fieldText('hostname', $vars->hostname ?? null, [
        'id' => 'hostname',
        'class' => 'form-control',
    ]); ?>
</div>

<div class="mb-3">
    <label for="api_token" class="form-label">
        <?php $this->_('VirtfusionDirectProvisioning.row_meta.api_token'); ?>
    </label>
    <?php $this->Form->fieldTextarea('api_token', $vars->api_token ?? null, [
        'id' => 'api_token',
        'class' => 'form-control',
    ]); ?>
</div>

<?php $this->Widget->footer(); ?>
<div class="d-flex justify-content-end">
    <?php $this->Form->fieldSubmit('save', $this->_('VirtfusionDirectProvisioning.edit_row.edit_btn', true), [
        'class' => 'btn btn-primary',
    ]); ?>
</div>

<?php
$this->Form->end();
$this->Widget->end();


